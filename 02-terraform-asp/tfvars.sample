# terraform.tfvars

# Confluent Cloud Credentials
# Found under "Administration" > "API Keys" 
# Must be a "Global/Cloud" key for infrastructure management
confluent_cloud_api_key    = "ABC123EXAMPLE"
confluent_cloud_api_secret = "cflt-very-long-secret-key-that-starts-with-cflt-prefix-2026"

# MongoDB Atlas Credentials
# Found under "Access Manager" > "Organization Settings" > "API Keys"
mongodbatlas_public_key  = "xxyyzzpp"
mongodbatlas_private_key = "12345678-abcd-1234-abcd-1234567890ab"
mongodbatlas_org_id      = "507f1f77bcf86cd799439011"

# Database User Settings
mongodb_password = "choose-a-secure-password-123"
